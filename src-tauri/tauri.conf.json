{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Red Wind",
  "version": "0.1.1",
  "identifier": "com.administrator.tauri-app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Red Wind",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/windRed-icon.png", "icons/icon.ico"]
  },
  "plugins": {
    "dialog": {
      "allow": true
    },
    "fs": {
      "allow": true
    },
    "os": {
      "allow": true
    },
    "shell": {
      "open": true
    }
  }
}
